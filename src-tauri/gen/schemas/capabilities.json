{"default":{"identifier":"default","description":"Default permissions for Caja. CSP is disabled in tauri.conf.json because the Tailwind browser runtime (CDN), blob: URLs for local assets, and the asset:// protocol require a permissive policy. Tauri's IPC security model is the primary security boundary, not CSP.","local":true,"windows":["main"],"permissions":["core:default","core:window:allow-start-dragging","opener:default","dialog:default","fs:default",{"identifier":"fs:allow-read-text-file","allow":[{"path":"$HOME/**"}]},{"identifier":"fs:allow-write-text-file","allow":[{"path":"$HOME/**"}]},{"identifier":"fs:allow-exists","allow":[{"path":"$HOME/**"}]},{"identifier":"fs:allow-mkdir","allow":[{"path":"$HOME/**"}]},{"identifier":"fs:allow-read-dir","allow":[{"path":"$HOME/**"}]},{"identifier":"fs:allow-remove","allow":[{"path":"$HOME/**"}]},{"identifier":"fs:allow-write-file","allow":[{"path":"$HOME/**"}]},{"identifier":"fs:allow-copy-file","allow":[{"path":"$HOME/**"}]},"fs:allow-appdata-read-recursive","fs:allow-appdata-write-recursive",{"identifier":"http:default","allow":[{"url":"https://**"},{"url":"http://**"}]},"window-state:default","updater:default","process:default"]}}